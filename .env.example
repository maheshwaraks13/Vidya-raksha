# VidyaRaksha — Environment Variables Template
# Copy this file to .env and fill in your values

# Flask
FLASK_ENV=development
SECRET_KEY=your-secret-key-change-this
JWT_SECRET_KEY=your-jwt-secret-change-this

# Database (SQLite for dev, PostgreSQL for production)
DATABASE_URL=sqlite:///data/vidyaraksha.db
# DATABASE_URL=postgresql://user:password@localhost:5432/vidyaraksha

# SMS Provider: 'fast2sms', 'twilio', or 'simulator'
SMS_PROVIDER=simulator

# Fast2SMS (India)
FAST2SMS_API_KEY=your-fast2sms-api-key

# Twilio (International)
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# Server
PORT=5000
